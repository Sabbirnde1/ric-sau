# ==============================================
# Local Development Environment Variables
# ==============================================
# This file is for LOCAL development only
# For Netlify: Set these in Site Settings → Environment variables
# ==============================================

# ---------------------------------------------
# Database Configuration (NEON PostgreSQL)
# ---------------------------------------------
# 🚀 Get your FREE Neon database:
# 1. Go to https://neon.tech
# 2. Sign up (free, no credit card)
# 3. Create project: "ric-sau"
# 4. Copy "Pooled" connection string
# 5. Paste below (replace the example)
#
# ⚠️ IMPORTANT: Must include ?sslmode=require at the end!
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech:5432/neondb?sslmode=require"

# For SQLite local testing only (won't work on Netlify):
# DATABASE_URL="file:./dev.db"

# ---------------------------------------------
# Authentication Secrets
# ---------------------------------------------
# JWT Secret - Generate a secure random string
# Example: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-change-this-to-random-string-for-production"

# Setup Secret - Used by /api/setup-db endpoint
SETUP_SECRET="setup-key-123"

# ---------------------------------------------
# Site URLs (Local Development)
# ---------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------
# 📝 NEXT STEPS TO CONNECT DATABASE:
# ---------------------------------------------
# 1. Replace DATABASE_URL above with your Neon connection string
# 2. Run: npm run db:push (creates tables in database)
# 3. Run: npm run db:seed (adds initial data)
# 4. Run: npm run dev (start development server)
# 5. Go to http://localhost:3000/login
#    - Username: admin
#    - Password: admin123
#
# Need help? Run: npm run db:setup
# ==============================================
