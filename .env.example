# MongoDB Atlas Connection
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/ric-sau?retryWrites=true&w=majority
MONGODB_DB=ric-sau

# JWT Secret for Authentication
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-long-random-string

# Base URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin Token (for localStorage - deprecated, will use JWT)
# adminToken = "loggedIn"
