# ==============================================
# Environment Variables Configuration
# ==============================================
# Copy this file to .env.local for local development
# For Netlify: Set these in Site Settings → Environment Variables
# ==============================================

# ---------------------------------------------
# Database Configuration (CRITICAL!)
# ---------------------------------------------
# ⚠️ IMPORTANT: This app REQUIRES PostgreSQL
# SQLite will NOT work on Netlify (serverless environment)
# 
# 🎯 RECOMMENDED: Neon Database (Free, Serverless, Fast)
# 1. Sign up at: https://neon.tech (no credit card required)
# 2. Create a new project: "ric-sau"
# 3. Copy the "Pooled" connection string
# 4. Paste below (must include ?sslmode=require)
#
# Example Neon connection string:
DATABASE_URL="postgresql://username:password@ep-abc-123.us-east-2.aws.neon.tech:5432/neondb?sslmode=require"

# Alternative providers:
# - Supabase: https://supabase.com  
# - Railway: https://railway.app
# - Heroku Postgres: https://www.heroku.com/postgres
#
# ⚠️ MUST include ?sslmode=require at the end!

# Local development ONLY (won't work on Netlify):
# DATABASE_URL="file:./dev.db"

# ---------------------------------------------
# Authentication
# ---------------------------------------------
# JWT Secret for token encryption
# Generate secure key: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev and production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-long-random-string

# Setup Secret for initial database initialization
# Used by /api/setup-db endpoint (set to anything secure)
SETUP_SECRET=your-setup-secret-change-this-123

# ---------------------------------------------
# Site Configuration
# ---------------------------------------------
# Base URLs - Update these for each environment
# Local Development:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (Netlify) - Update after deployment:
# NEXT_PUBLIC_BASE_URL=https://your-site.netlify.app
# NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Custom Domain (if configured):
# NEXT_PUBLIC_BASE_URL=https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ---------------------------------------------
# Optional: Email Configuration (Future)
# ---------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# EMAIL_FROM=noreply@yourdomain.com

# ---------------------------------------------
# Optional: File Upload (Future)
# ---------------------------------------------
# UPLOAD_MAX_SIZE=5242880
# ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ---------------------------------------------
# Optional: Analytics (Future)
# ---------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

